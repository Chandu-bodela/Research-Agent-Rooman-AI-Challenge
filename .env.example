# ============================================================================
# ResearchMind AI — Environment Configuration
# Copy this file to `.env` and fill in the values you need.
# You only need ONE LLM provider's API key — set LLM_PROVIDER accordingly.
# ============================================================================

# Which LLM provider to use: openai | anthropic | gemini | groq
LLM_PROVIDER=groq

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Groq (fast, free-tier friendly Llama 3 access) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- LLM generation params ---
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=800

# --- Embeddings & retrieval ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=4
SIMILARITY_THRESHOLD=0.15

# Optional but recommended for clean startup on fresh environments.
# Some transformers models import torchvision during import-time.
TORCHVISION=1
